    {
      "type": "text",
      "id": "rot_step1",
      "x": 80,
      "y": 328,
      "width": 760,
      "height": 20,
      "text": "Step 1: global rotation G applied to world  →  every camera's rotation updates: R_i → G R_i  (all cameras get the same left-multiply G)",
      "originalText": "Step 1: global rotation G applied to world  →  every camera's rotation updates: R_i → G R_i  (all cameras get the same left-multiply G)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 26,
      "version": 1,
      "versionNonce": 27,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "rot_step2",
      "x": 80,
      "y": 356,
      "width": 760,
      "height": 20,
      "text": "Step 2: therefore P_i → G P_i  and  P_j → G P_j  (same G, same left-multiply)",
      "originalText": "Step 2: therefore P_i → G P_i  and  P_j → G P_j  (same G, same left-multiply)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
