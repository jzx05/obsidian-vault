    {
      "type": "text",
      "id": "trans_result",
      "x": 510,
      "y": 134,
      "width": 320,
      "height": 100,
      "text": "R_i unchanged\nt_i → t_i + d  (but t_i not in P_i!)\n\n∴ P_i unchanged\n∴ P_i^T P_j unchanged  ✓",
      "originalText": "R_i unchanged\nt_i → t_i + d  (but t_i not in P_i!)\n\n∴ P_i unchanged\n∴ P_i^T P_j unchanged  ✓",
