    {
      "type": "text",
      "id": "pi_struct_t",
      "x": 90,
      "y": 134,
      "width": 320,
      "height": 100,
      "text": "P_i = block-diag( K_i^{-T} R_i ,  K_i^{-T} )\n\n      contains R_i (rotation)\n      contains K_i (intrinsic)\n      NO translation t_i !",
      "originalText": "P_i = block-diag( K_i^{-T} R_i ,  K_i^{-T} )\n\n      contains R_i (rotation)\n      contains K_i (intrinsic)\n      NO translation t_i !",
