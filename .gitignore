# ============================================
# Obsidian 工作区文件（每台电脑不同，不要同步）
# ============================================
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace.json.bak
.obsidian/cache/
.obsidian/plugins/*/data.json.bak

# Obsidian 回收站
.trash/

# Claudian 会话缓存（每台电脑独立，不要同步）
.claudian/sessions/
.claudian/cache/

# ============================================
# 系统垃圾文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.swp
*~

# ============================================
# 大文件（建议走 Git LFS 或单独云盘）
# ============================================
# 取消下面的注释 = 不把综述 PDF 同步到 git
# WAM/06-综述/*.pdf
# **/attachments/*.mp4
# **/attachments/*.mov

# ============================================
# 本地敏感配置
# ============================================
.env
*.local
